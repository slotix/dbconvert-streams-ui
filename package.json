{
  "name": "dbconvert-streams-ui",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite preview --port $PORT --host 127.0.0.1",
    "test:unit": "vitest",
    "test:sql-lsp": "vitest run src/__tests__/useSqlLspProviders.test.ts src/__tests__/UnifiedConsoleTab.schemaContextRace.test.ts src/__tests__/useQueryExecutionDestructive.test.ts src/__tests__/sqlCodeMirrorLspUtils.test.ts src/__tests__/sqlCodeMirrorHoverUtils.test.ts",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "version:patch": "git add . && git commit -m \"chore: prepare for patch release\" && npm version patch",
    "version:minor": "git add . && git commit -m \"chore: prepare for minor release\" && npm version minor",
    "version:major": "git add . && git commit -m \"chore: prepare for major release\" && npm version major"
  },
